# Yautja-Vision Bio-Mask HUD Configuration

# OpenAI / LM Studio / Ollama API Key
# If using local models (LM Studio/Ollama), this can be any string.
OPENAI_API_KEY=YOUR_API_KEY_HERE

# Base URL for the LLM API
# Default: http://127.0.0.1:1234/v1 (LM Studio)
# For Ollama: http://127.0.0.1:11434/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# The model name to use
OPENAI_MODEL=qwen/qwen2.5-vl-7b
